# Server config
PORT=4000

# Agent chat + background briefings (OpenAI tool-calling)
OPENAI_API_KEY=
# Optional — default gpt-4o-mini
AGENT_OPENAI_MODEL=gpt-4o-mini
# Optional caps
AGENT_MAX_MESSAGE_CHARS=8000
AGENT_RATE_LIMIT_PER_MINUTE=30

# Machine-to-Machine API for harness / automation (Bearer token)
# If unset, INTERNAL_SERVICE_TOKEN is also accepted.
INTERNAL_API_TOKEN=

# Optional: proxy to external harness (e.g. claw rust server)
HARNESS_SERVER_URL=
HARNESS_UPSTREAM_TOKEN=
# Service-to-harness auth: Bearer INTERNAL_SERVICE_TOKEN + header X-User-Id
INTERNAL_SERVICE_TOKEN=

# Weekly briefings cron (optional)
ENABLE_REPORT_CRON=false
REPORT_CRON_EXPRESSION=0 6 * * 0
CRON_SECRET=

# Optional: if provided, LLM sentiment analysis is used via Google Gemini.
# If missing, the app falls back to keyword-based sentiment.
GEMINI_API_KEY=
GEMINI_PROJECT_ID=projects/YOUR_PROJECT_NUMBER
# Optional: comma-separated fallback model list (left-to-right)
# Use currently supported models for your API version/project.
GEMINI_MODELS=gemini-1.5-flash,gemini-1.5-pro
