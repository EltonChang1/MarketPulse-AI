# Server config
PORT=4000

# Optional: if provided, LLM sentiment analysis is used via Google Gemini.
# If missing, the app falls back to keyword-based sentiment.
GEMINI_API_KEY=
GEMINI_PROJECT_ID=projects/YOUR_PROJECT_NUMBER
# Optional: comma-separated fallback model list (left-to-right)
# Use currently supported models for your API version/project.
GEMINI_MODELS=gemini-1.5-flash,gemini-1.5-pro
